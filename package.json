{
  "name": "awaitful-client-mirror",
  "version": "0.0.0",
  "private": true,
  "description": "Public, read-only mirror of the Awaitful client (VS Code extension, npx installer, and the API contract it speaks).",
  "scripts": {
    "build": "pnpm --filter @awaitful/shared build && pnpm --filter awaitful build",
    "typecheck": "pnpm -r typecheck",
    "package": "pnpm --filter awaitful exec vsce package --no-dependencies"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@11.9.0"
}
